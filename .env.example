# Optional local MLX server target for smoke-openai-compatible-mlx.sh and test-qmd-pr619-vmlx.sh
QMD_MLX_BASE_URL=http://127.0.0.1:8000/v1

# vMLX may advertise aliases in /v1/models but reject them on /v1/embeddings.
# For the current vMLX path, prefer the exact local model directory.
QMD_MLX_EMBED_MODEL=/absolute/path/to/models/mlx/mlx-community__Qwen3-Embedding-0.6B-4bit-DWQ
QMD_MLX_RERANK_MODEL=mlx-community/Qwen3-Reranker-0.6B-mxfp8
QMD_MLX_GENERATE_MODEL=qmd-embed
