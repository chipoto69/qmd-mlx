+    def _is_causal_reranker_model(self, model_path: str) -> bool:
+        """Check if model should use CausalLM yes/no logit scoring.
+
+        Qwen3-Reranker is packaged as Qwen3ForCausalLM. mlx_embeddings.load()
+        can load it, but returns BaseModelOutput hidden states without logits;
+        the encoder scorer then crashes on output.shape. Route these models to
+        mlx_lm instead.
+        """
+        resolved = self._resolve_model_path(model_path)
+        if not resolved:
+            return False
+
+        config_path = os.path.join(resolved, "config.json")
+        architectures: list[str] = []
+        try:
+            import json
+            with open(config_path, "r", encoding="utf-8") as fh:
+                config = json.load(fh)
+            raw_architectures = config.get("architectures") or []
+            if isinstance(raw_architectures, list):
+                architectures = [str(item) for item in raw_architectures]
+        except Exception:
+            architectures = []
+
+        lowered_path = model_path.lower()
+        return (
+            any(arch.endswith("ForCausalLM") for arch in architectures)
+            and "reranker" in lowered_path
+        )
+
     @staticmethod
     def _resolve_model_path(model_path: str) -> str | None:
         """Resolve a HF model ID or local path to a directory."""
